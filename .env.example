# ============================================================================
# Discovery Agent — environment configuration
# Copy to `.env` and fill in your free-tier API keys.
# ============================================================================

# --- API keys (free tier) ---
# Gemini: https://aistudio.google.com/apikey  (no credit card)
GEMINI_API_KEY=
# Groq: https://console.groq.com/keys  (no credit card)
GROQ_API_KEY=

# --- Model selection (free-tier model IDs rotate; override here if needed) ---
# Gemini handles vision + extraction + reasoning (L1, L2)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
# Groq handles fast code generation (L3)
GROQ_CODE_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# --- Task routing: which provider handles which task (gemini | groq) ---
ROUTE_EXTRACTION=gemini
ROUTE_VISION=gemini
ROUTE_GAP_ANALYSIS=gemini
ROUTE_CODEGEN=groq

# --- Confidence thresholds (Level 1 policy) ---
CONFIDENCE_EXPLICIT=0.95
CONFIDENCE_INFERRED=0.70

# --- Rate limiting (free-tier safe defaults) ---
GEMINI_RPM=10
GROQ_RPM=30
LLM_MAX_RETRIES=5

# --- Behaviour ---
# If true, missing OCR (Tesseract) for an image with no vision available is a hard,
# reported failure rather than a silent skip.
STRICT_INGEST=true
RUN_LEDGER_DIR=data/runs
