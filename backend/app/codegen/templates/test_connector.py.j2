BASE_URL = "https://api.example.test"
{% set e = entities[0] %}


class FakeResponse:
    def __init__(self, status_code=200, json_data=None, headers=None):
        self.status_code = status_code
        self._json = json_data
        self.headers = headers or {}
        self.text = "" if json_data is None else str(json_data)
        self.content = b"" if json_data is None else b"x"

    def json(self):
        return self._json


class FakeSession:
    """Returns queued responses for .request; a fixed token for .post (OAuth)."""

    def __init__(self, responses):
        self._responses = list(responses)
        self.calls = []

    def request(self, method, url, **kwargs):
        self.calls.append((method, url, kwargs))
        if self._responses:
            return self._responses.pop(0)
        return FakeResponse(200, {})

    def post(self, url, **kwargs):
        return FakeResponse(200, {"access_token": "test-token", "expires_in": 3600})

    def close(self):
        pass


def _make(session, **over):
{% if auth.type == "oauth2_client_credentials" %}
    kwargs = dict(base_url=BASE_URL, client_id="id", client_secret="secret",
                  token_url=BASE_URL + "/token", session=session)
{% elif auth.type == "basic" %}
    kwargs = dict(base_url=BASE_URL, username="u", password="p", session=session)
{% else %}
    kwargs = dict(base_url=BASE_URL, api_key="test-key", session=session)
{% endif %}
    kwargs.update(over)
    return {{ class_name }}(**kwargs)


@pytest.fixture(autouse=True)
def _no_sleep(monkeypatch):
    monkeypatch.setattr(time, "sleep", lambda *_a, **_k: None)


def test_auth_headers_present():
    c = _make(FakeSession([]))
    headers = c._auth_headers()
    assert any(v for v in headers.values())


def test_missing_base_url_raises(monkeypatch):
    monkeypatch.delenv("{{ base_url_env }}", raising=False)
    with pytest.raises(Exception):
        _make(FakeSession([]), base_url="")


def test_list_{{ e.method }}_yields_items():
    page = {"{{ e.list_path or 'data' }}": [{"{{ e.id_field }}": "1"}, {"{{ e.id_field }}": "2"}]}
    c = _make(FakeSession([FakeResponse(200, page), FakeResponse(200, {"{{ e.list_path or 'data' }}": []})]))
    items = list(c.list_{{ e.method }}())
    assert len(items) >= 2
    assert items[0]["{{ e.id_field }}"] == "1"


def test_get_{{ e.method }}_calls_api():
    session = FakeSession([FakeResponse(200, {"{{ e.id_field }}": "42"})])
    c = _make(session)
    obj = c.get_{{ e.method }}("42")
    assert obj["{{ e.id_field }}"] == "42"
    assert session.calls[-1][0] == "GET"


def test_create_{{ e.method }}_posts():
    session = FakeSession([FakeResponse(201, {"{{ e.id_field }}": "new"})])
    c = _make(session)
    created = c.create_{{ e.method }}({"field": "value"})
    assert created["{{ e.id_field }}"] == "new"
    assert session.calls[-1][0] == "POST"


def test_update_and_delete_{{ e.method }}():
    session = FakeSession([FakeResponse(200, {"{{ e.id_field }}": "1"}), FakeResponse(204, None)])
    c = _make(session)
    c.update_{{ e.method }}("1", {"field": "v"})
    assert session.calls[-1][0] == "PATCH"
    c.delete_{{ e.method }}("1")
    assert session.calls[-1][0] == "DELETE"


def test_not_found_maps_to_error():
    c = _make(FakeSession([FakeResponse(404, {"error": "nope"})]))
    with pytest.raises({{ class_name }}NotFoundError):
        c.get_{{ e.method }}("missing")


def test_rate_limit_retries_then_succeeds():
    c = _make(FakeSession([
        FakeResponse(429, None, headers={"Retry-After": "0"}),
        FakeResponse(200, {"{{ e.id_field }}": "ok"}),
    ]))
    obj = c.get_{{ e.method }}("ok")
    assert obj["{{ e.id_field }}"] == "ok"


def test_auth_error_on_401():
    c = _make(FakeSession([FakeResponse(401, {"error": "bad"})]))
    with pytest.raises({{ class_name }}AuthError):
        c.get_{{ e.method }}("x")
