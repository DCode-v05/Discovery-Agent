class {{ class_name }}RateLimitError({{ class_name }}Error):
    """The API rate limit was exceeded after all retries."""


# --------------------------------------------------------------------------- #
# Rate limiter
# --------------------------------------------------------------------------- #
class _RateLimiter:
    """Thread-safe minimum-interval limiter ({{ rate_limit_per_sec }} req/sec)."""

    def __init__(self, per_second: float):
        self._min_interval = 1.0 / per_second if per_second > 0 else 0.0
        self._lock = threading.Lock()
        self._last = 0.0

    def acquire(self) -> None:
        with self._lock:
            wait = self._min_interval - (time.monotonic() - self._last)
            if wait > 0:
                time.sleep(wait)
            self._last = time.monotonic()


