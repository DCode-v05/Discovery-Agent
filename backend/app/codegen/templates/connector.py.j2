    # -- core request with retries + rate limiting ------------------------- #
    def _request(self, method: str, path: str, **kwargs: Any) -> Any:
        url = path if path.startswith("http") else f"{self.base_url}{path}"
        headers = {"Accept": "application/json", **self._auth_headers(), **kwargs.pop("headers", {})}
        last_exc: Exception | None = None
        for attempt in range(MAX_RETRIES):
            self._rate_limiter.acquire()
            try:
                resp = self._session.request(method, url, headers=headers,
                                             timeout=DEFAULT_TIMEOUT, **kwargs)
            except requests.RequestException as exc:
                last_exc = exc
                time.sleep(min(2 ** attempt, 30))
                continue

            if resp.status_code == 429 or resp.status_code >= 500:
                retry_after = resp.headers.get("Retry-After")
                delay = float(retry_after) if retry_after else min(2 ** attempt, 30)
                logger.warning("%s %s -> %s; retrying in %.1fs", method, url, resp.status_code, delay)
                time.sleep(delay)
                last_exc = {{ class_name }}RateLimitError(f"{resp.status_code} from {url}")
                continue
            if resp.status_code in (401, 403):
                raise {{ class_name }}AuthError(f"Auth failed ({resp.status_code}): {resp.text}")
            if resp.status_code == 404:
                raise {{ class_name }}NotFoundError(f"Not found: {url}")
            if resp.status_code >= 400:
                raise {{ class_name }}Error(f"Request failed ({resp.status_code}): {resp.text}")
            if not resp.content:
                return None
            return resp.json()
        raise last_exc or {{ class_name }}Error(f"{method} {url} failed after {MAX_RETRIES} attempts")

    @staticmethod
    def _extract_list(payload: Any, list_path: str) -> list[dict]:
        if not list_path:
            return payload if isinstance(payload, list) else payload.get("data", []) or []
        node = payload
        for part in list_path.split("."):
            node = node.get(part, {}) if isinstance(node, dict) else {}
        return node if isinstance(node, list) else []

