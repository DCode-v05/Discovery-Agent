    # -- authentication ---------------------------------------------------- #
{% if auth.type == "oauth2_client_credentials" %}
    def _ensure_token(self) -> str:
        if self._token and time.monotonic() < self._token_expiry - 30:
            return self._token
        if not (self.client_id and self.client_secret):
            raise {{ class_name }}AuthError(
                "Missing OAuth credentials: set {{ env_prefix }}_CLIENT_ID and {{ env_prefix }}_CLIENT_SECRET."
            )
        data = {
            "grant_type": "client_credentials",
            "client_id": self.client_id,
            "client_secret": self.client_secret,
{% if auth.scopes %}
            "scope": "{{ auth.scopes | join(' ') }}",
{% endif %}
        }
        resp = self._session.post(self.token_url, data=data, timeout=DEFAULT_TIMEOUT)
        if resp.status_code >= 400:
            raise {{ class_name }}AuthError(f"Token request failed ({resp.status_code}): {resp.text}")
        payload = resp.json()
        self._token = payload["access_token"]
        self._token_expiry = time.monotonic() + float(payload.get("expires_in", 3600))
        return self._token

    def _auth_headers(self) -> dict[str, str]:
        return {"{{ auth.header_name }}": f"Bearer {self._ensure_token()}"}
{% elif auth.type == "basic" %}
    def _auth_headers(self) -> dict[str, str]:
